  "keyFeatures": [
    "Read and parse VPK v1 and v2 archives",
    "Extract individual files or entire archives",
    "Create new VPK packages programmatically",
    "Verify MD5, Blake3, and CRC32 checksums",
    "Validate RSA signatures",
    "Memory-mapped file access for performance",
    "Binary search optimization for fast lookups",
    "Support for split archive files (_dir.vpk)"
  ],
